      <div class={styles["visual-side"]} data-gsap="visual">
        <div class={styles["device-mockup"]}>
          <div class={styles["device-frame"]}>
            <div class={styles["device-notch"]}></div>
            <div class={styles["device-screen"]}>
              {
                pinnedVideos.map((src, index) => (
                  <video
                    src={src}
                    muted
                    loop={false}
                    playsinline
                    preload="auto"
                    width="720"
                    height="1280"
                    class={styles["device-video"]}
                    data-mockup-video
                    data-active={index === 0 ? "true" : "false"}
                    style={{ opacity: index === 0 ? 1 : 0 }}
