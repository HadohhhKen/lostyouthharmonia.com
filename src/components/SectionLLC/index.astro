---
import { Image, getImage } from "astro:assets";
import styles from "./index.module.scss";
import bgDesktop from "../../assets/images/section-llc/bg.png";
import bgMobile from "../../assets/images/section-llc/bg-sp.png";

// Optimize background images
const bgDesktopOpt = await getImage({ src: bgDesktop, format: "avif" });
const bgMobileOpt = await getImage({ src: bgMobile, format: "avif" });
const bgFallback = await getImage({ src: bgDesktop, format: "jpeg" });

import instagramData from "../../data/instagram.json";

// Pinned Post IDs - consistent with InstagramFeed
const PINNED_POST_IDS = [
  "3824109189711481931_79963192301", // Story 01 (Rainy girl)
  "3818326888394212863_79963192301", // System Status: Breached (Reel)
  //"3820500952948928608_79963192301", // Break My Fall (Poster)
];

// Extract videos for pinned posts and prepend the main promo video
const pinnedVideos = [
  "/assets/video/break-my-fall.mp4", // Main Promo Video (First)
  ...(instagramData as any[])
    .filter((post) => PINNED_POST_IDS.includes(post.id))
    .sort(
      (a, b) => PINNED_POST_IDS.indexOf(a.id) - PINNED_POST_IDS.indexOf(b.id),
    )
    .map((post) => {
      const videoAsset = post.assets.find((a: any) => a.type === "video");
      return videoAsset ? videoAsset.localPath : null;
    })
    .filter(Boolean),
];
---

<section id="overview" class={styles.SectionLLC}>
  <picture>
    <source
      media="(max-width: 768px)"
      srcset={bgMobileOpt.src}
      type="image/avif"
    />
    <source
      media="(min-width: 769px)"
      srcset={bgDesktopOpt.src}
