<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initAnimations = () => {
    const section = document.getElementById("overview");
    if (!section) return;

    const introOverlay = document.getElementById("global-intro-overlay");
    const card = section.querySelector('[data-gsap="card"]');
    const title = section.querySelector('[data-gsap="title"]');
    const dsp = section.querySelector('[data-gsap="dsp"]');
    const stats = section.querySelectorAll('[data-gsap="stat"]');
    const visual = section.querySelector('[data-gsap="visual"]');
    const overlay = section.querySelector('[data-gsap="overlay"]');

    // Initial state
    gsap.set(introOverlay, { xPercent: 0 });
    gsap.set(card, { y: 40, autoAlpha: 0 });
    gsap.set(title, { x: -20, autoAlpha: 0 });
    gsap.set(dsp, { y: 10, autoAlpha: 0 });
    gsap.set(stats, { scale: 0.8, autoAlpha: 0 });
    gsap.set(visual, { x: 20, autoAlpha: 0 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top 80%",
        once: true,
      },
      delay: 0.2, // Small delay after reveal
    });

    tl.to(introOverlay, {
      xPercent: 100,
      duration: 1.2,
      ease: "expo.inOut",
    })
      .to(
        card,
        { y: 0, autoAlpha: 1, duration: 0.8, ease: "power3.out" },
        "-=1.2",
      )
      .to(
        [title, dsp],
        {
          x: 0,
          y: 0,
          autoAlpha: 1,
          duration: 0.6,
          stagger: 0.1,
          ease: "power2.out",
        },
        "-=0.4",
      )
      .to(
        visual,
        { x: 0, autoAlpha: 1, duration: 0.8, ease: "power2.out" },
        "-=0.6",
      )
      .to(
        stats,
        {
          scale: 1,
          autoAlpha: 1,
          duration: 0.5,
          stagger: 0.1,
          ease: "back.out(1.7)",
        },
        "-=0.4",
      );

    // Background opacity scrub - Fixed to Dark Theme
    const baseColor = "rgba(0, 0, 0, 0.5)";
    const midColor = "rgba(0, 0, 0, 0.85)";

    gsap.set(overlay, {
      backgroundColor: baseColor,
      backdropFilter: "blur(0px)",
      webkitBackdropFilter: "blur(0px)",
    });

    const overlayTl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top top",
        end: "bottom bottom",
        scrub: true,
      },
    });

    overlayTl
      .to(overlay, {
        backgroundColor: midColor,
        backdropFilter: "blur(4px)",
        webkitBackdropFilter: "blur(4px)",
        duration: 1,
      })
      .to(overlay, {
        backgroundColor: baseColor,
        backdropFilter: "blur(8px)",
        webkitBackdropFilter: "blur(8px)",
        duration: 1,
      });

    // --- Device Video Cross-fade Loop ---
    const videos = section.querySelectorAll(
      "video[data-mockup-video]",
    ) as NodeListOf<HTMLVideoElement>;
    let currentIndex = 0;

    const switchVideo = () => {
      const currentVideo = videos[currentIndex];
      const nextIndex = (currentIndex + 1) % videos.length;
      const nextVideo = videos[nextIndex];

      // Prepare next video
      nextVideo.currentTime = 0;
      nextVideo.play();

      // Fade out current, Fade in next
      gsap.to(currentVideo, {
        opacity: 0,
        duration: 1.2,
        ease: "power2.inOut",
        onComplete: () => {
          currentVideo.pause();
          currentVideo.setAttribute("data-active", "false");
        },
      });

      gsap.to(nextVideo, {
        opacity: 1,
        duration: 1.2,
        ease: "power2.inOut",
        onComplete: () => {
          nextVideo.setAttribute("data-active", "true");
          currentIndex = nextIndex;
        },
      });
    };

    // --- Start Playback Immediately ---
    if (videos.length > 0) {
      videos[0].play();

      // Loop interval (18s)
      setInterval(() => {
        if (document.hidden) return;
        switchVideo();
      }, 18000);
    }

    // --- Meta Pixel Tracking for DSP Links ---
    const dspButtons = section.querySelectorAll("[data-track-dsp]");
    dspButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const platform = btn.getAttribute("data-track-dsp");
        // @ts-ignore - fbq is loaded globally
        if (typeof fbq === "function") {
          // @ts-ignore
          fbq("track", "FindLocation", {
            content_name: platform,
            content_category: "DSP Link",
          });
        }
      });
    });
  };

  // Run on preloader complete or immediately if skipped
  if (sessionStorage.getItem("visited")) {
    initAnimations();
  } else {
    window.addEventListener("preloaderStartFade", initAnimations);
  }
</script>
