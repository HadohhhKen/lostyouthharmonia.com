---
import { Image, getImage } from "astro:assets";
import instagramData from "../../data/instagram.json";
import styles from "./index.module.scss";

// Resolve all local images from the assets folder
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/instagram/*.{jpeg,jpg,png,gif}",
);

interface IgAsset {
  type: "image" | "video";
  url: string;
  localPath: string;
  width?: number;
  height?: number;
}

interface IgPost {
  id: string;
  code: string;
  type: number;
  caption: string;
  date: string;
  timestamp: number;
  assets: IgAsset[];
  is_pinned?: boolean; // Added for pinned status
}

// Pinned Post IDs identified from the screenshot
const PINNED_POST_IDS = [
  "3824109189711481931_79963192301", // Story 01 (Rainy girl)
  "3818326888394212863_79963192301", // System Status: Breached (Reel)
  "3820500952948928608_79963192301", // Break My Fall (Poster)
];

// Sort posts: Pinned first (respecting PINNED_POST_IDS order), then by date ascending, max 36 items
const sortedPosts = (instagramData as IgPost[])
  .sort((a, b) => {
    const indexA = PINNED_POST_IDS.indexOf(a.id);
    const indexB = PINNED_POST_IDS.indexOf(b.id);
    const isPinnedA = a.is_pinned || indexA !== -1;
    const isPinnedB = b.is_pinned || indexB !== -1;

    // 1. Priority to pinned posts
    if (isPinnedA && !isPinnedB) return -1;
    if (!isPinnedA && isPinnedB) return 1;

    // 2. If both are pinned, respect the order in PINNED_POST_IDS
    if (isPinnedA && isPinnedB) {
      return indexA - indexB;
    }

    // 3. Ascending order for non-pinned posts (oldest first)
    return new Date(a.date).getTime() - new Date(b.date).getTime();
  })
  .slice(0, 36);

// Resolve all poster images and main images asynchronously
const resolvedPosts = await Promise.all(
  sortedPosts.map(async (post) => {
    const mainAsset = post.assets[0];
    const imagePath =
      mainAsset.type === "image"
        ? mainAsset.localPath
        : post.assets.find((a) => a.type === "image")?.localPath;
    const videoAsset = post.assets.find((a) => a.type === "video");
    const isCarousel = post.type === 8;

    let posterSrc = "";
    if (imagePath && images[imagePath]) {
      const img = await images[imagePath]();
      const optimized = await getImage({
        src: img.default,
        width: 400,
        height: 500,
        format: "webp",
      });
      posterSrc = optimized.src;
    }

    return {
      ...post,
      imagePath,
      videoAsset,
      isCarousel,
      posterSrc,
    };
  }),
);
---

<section id="feed" class={styles["InstagramFeed"]}>
  <div class={styles["InstagramFeed__grid"]} data-gsap="ig-feed">
    {
      resolvedPosts.map((post) => {
        const { imagePath, videoAsset, isCarousel, posterSrc } = post;

        return (
          <article
            class={styles["InstagramFeed__item"]}
            data-type={post.type}
            data-code={post.code}
            data-ig-item
            data-gsap="ig-item"
          >
            <a
              href={
                post.type === 2
                  ? `https://www.instagram.com/reels/${post.code}/`
                  : `https://www.instagram.com/p/${post.code}/`
              }
              target="_blank"
              rel="noopener noreferrer"
              class={styles["InstagramFeed__link"]}
            >
              <div class={styles["InstagramFeed__media-container"]}>
                {videoAsset ? (
                  <video
                    src={videoAsset.localPath}
                    class={styles["InstagramFeed__video"]}
                    muted
                    loop
                    playsinline
                    poster={posterSrc}
                  />
                ) : imagePath && images[imagePath] ? (
                  <Image
                    src={images[imagePath]()}
                    alt={post.caption.substring(0, 50)}
                    width={400}
                    height={500}
                    class={styles["InstagramFeed__image"]}
                  />
                ) : null}

                {isCarousel && (
                  <div class={styles["InstagramFeed__carousel-icon"]}>
                    <svg
                      viewBox="0 0 24 24"
                      fill="white"
                      width="18"
                      height="18"
                    >
                      <path d="M19 19H5V5h14v14zM5 3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2H5z" />
                      <path d="M21 7h2v14c0 1.1-.9 2-2 2H7v-2h14V7z" />
                    </svg>
                  </div>
                )}

                {videoAsset && (
                  <div class={styles["InstagramFeed__video-icon"]}>
                    <svg
                      viewBox="0 0 24 24"
                      fill="white"
                      width="18"
                      height="18"
                    >
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" />
                    </svg>
                  </div>
                )}
              </div>

              <div class={styles["InstagramFeed__overlay"]}>
                <p class={styles["InstagramFeed__caption"]}>
                  {post.caption.substring(0, 100)}
                  {post.caption.length > 100 ? "..." : ""}
                </p>
                <time class={styles["InstagramFeed__date"]}>
                  {new Date(post.date).toLocaleDateString("ja-JP")}
                </time>
              </div>
            </a>
          </article>
        );
      })
    }
  </div>

  <div class={styles["InstagramFeed__footer"]}>
    <a
      href="https://www.instagram.com/lost_youth_harmonia/"
      target="_blank"
      rel="noopener noreferrer"
      class={styles["InstagramFeed__cta"]}
    >
      <span>Follow on Instagram</span>
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        width="18"
        height="18"
      >
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
      </svg>
    </a>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initFeed = () => {
    const feed = document.querySelector('[data-gsap="ig-feed"]');
    if (!feed) return;

    const items = feed.querySelectorAll('[data-gsap="ig-item"]');

    // Initial state
    gsap.set(items, { scale: 0.5, autoAlpha: 0 });

    // Entrance Animation
    gsap.to(items, {
      scale: 1,
      autoAlpha: 1,
      duration: 0.8,
      stagger: 0.15,
      ease: "back.out(1.2)",
      scrollTrigger: {
        trigger: feed,
        start: "top 85%",
        toggleActions: "play none none none",
        once: true,
      },
    });

    // Video Hover Playback
    items.forEach((item) => {
      const video = item.querySelector("video") as HTMLVideoElement;
      if (video) {
        item.addEventListener("mouseenter", () => video.play());
        item.addEventListener("mouseleave", () => {
          video.pause();
          video.currentTime = 0.1;
        });
      }
    });
  };

  // Run on load
  document.addEventListener("DOMContentLoaded", initFeed);
</script>
